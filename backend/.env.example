SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=documents

# Supabase JWT secret (Settings > Auth > JWT Secret)
JWT_SECRET=your_jwt_secret

# Postgres connection string (Supabase Dashboard > Database > Connection string)
DATABASE_URL=postgresql://postgres:password@db.server:5432/postgres?sslmode=require

ANTHROPIC_API_KEY=your_anthropic_api_key

# xAI Grok (optional; used as fallback when Anthropic/OpenAI are blocked)
GROK_API_KEY=
GROK_MODEL=grok-4-0709

# Preferred answer-generation provider: grok | anthropic | openai
LLM_PROVIDER=grok

# Optional: fallback embeddings if local sentence-transformers fails
OPENAI_API_KEY=

# Embedding output size must match your pgvector schema (your current schema uses vector(384))
EMBEDDINGS_DIM=384
EMBEDDINGS_PROVIDER=openai

# CORS
FRONTEND_URL=http://localhost:3000

# Upload safety
MAX_UPLOAD_MB=10

