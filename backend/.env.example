SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=documents

# Supabase JWT secret (Settings > Auth > JWT Secret)
JWT_SECRET=your_jwt_secret

# Postgres connection string (Supabase Dashboard > Database > Connection string)
DATABASE_URL=postgresql://postgres:password@db.server:5432/postgres?sslmode=require

ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Gemini (Google AI Studio) — recommended primary LLM when you have credits
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# xAI Grok (optional fallback)
GROK_API_KEY=
GROK_MODEL=grok-4-0709

# Preferred answer-generation provider: gemini | grok | anthropic | openai
LLM_PROVIDER=gemini

# OpenAI: optional for chat fallback and/or embeddings. If you have no credits, leave empty and use local embeddings.
OPENAI_API_KEY=

# Embeddings: must match pgvector column dim (384). Use `local` when OpenAI has no quota (sentence-transformers).
EMBEDDINGS_DIM=384
EMBEDDINGS_PROVIDER=local

# Public app URL (CORS + Supabase email confirmation redirect). Use production URL on Railway/Vercel.
FRONTEND_URL=http://localhost:3000

# Upload safety
MAX_UPLOAD_MB=10

