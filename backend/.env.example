SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=documents

# Supabase JWT secret (Settings > Auth > JWT Secret)
JWT_SECRET=your_jwt_secret

# Postgres connection string (Supabase Dashboard > Database > Connection string)
DATABASE_URL=postgresql://postgres:password@db.server:5432/postgres?sslmode=require

# Google Gemini — only external LLM API used for answers (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Embeddings: local MiniLM (384-dim). No OpenAI / other embedding API.
EMBEDDINGS_DIM=384
EMBEDDINGS_PROVIDER=local

# Public app URL (CORS + Supabase email confirmation redirect). Use production URL on Railway/Vercel.
FRONTEND_URL=http://localhost:3000

# Upload safety
MAX_UPLOAD_MB=10

# Local debugging: set to 1 to add a `debug` object on POST /query JSON (similarities, Gemini errors, chunk preview).
# RAG_DEBUG=1
